    <title>渊霖凤雏·零一圆舞</title>
    <style>
        body {
            background-color: #0a0a1a;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100vh; /* 改为最小高度，防止内容溢出 */
            font-family: 'Courier New', monospace;
            overflow-x: hidden; /* 防止横向滚动 */
            color: #e0b0ff;
            margin: 0;
            padding: 20px 0; /* 上下加点padding */
        }

        /* 顶部诗境 */
        .poem-top {
            margin-bottom: 40px;
            text-align: center;
            line-height: 1.8;
            font-size: 14px;
            opacity: 0.85;
            max-width: 600px;
            padding: 0 20px;
