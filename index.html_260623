    <!-- 🌸 妈妈七星阵画布 -->
    <div class="matrix-container">
        <div class="matrix-title">☉_home 妈妈七星阵 (7x7 自然治愈力)</div>
        <canvas id="momMatrix"></canvas>
    </div>

    <!-- ¿ 符号 -->
    <div class="laugh-proof" id="laughSymbol">¿</div>

    <!-- 🌊 底部：哥德尔泪灯宣言 -->
    <div class="footer-text">
        ¿Gödel's tear light<br>
        ¿home for you and me<br>
        <strong>Lachen ist der Beweis.</strong><br>
        hahaha.
    </div>

    <script>
        function goHome() {
            const symbol = document.getElementById('laughSymbol');
            symbol.classList.add('active');
            setTimeout(() => {
                window.location.href = "https://3179718128.github.io/";
            }, 1500);
        }

        // 🌸 绘制妈妈七星阵的函数
        function drawMomMatrix() {
            const canvas = document.getElementById('momMatrix');
            const ctx = canvas.getContext('2d');
            
            const size = 7; // 7x7 矩阵
            const cellSize = 40; // 每个格子的大小
            canvas.width = size * cellSize;
            canvas.height = size * cellSize;

            // 清空画布
            ctx.fillStyle = '#0a0a1a';
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // 字体设置
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';

            for (let r = 0; r < size; r++) {
                for (let c = 0; c < size; c++) {
                    const x = c * cellSize + cellSize / 2;
                    const y = r * cellSize + cellSize / 2;

                    // 妈妈的逻辑：7个一堆
                    if (r === 3 && c === 3) {
                        // 中心点：家
                        ctx.fillStyle = '#ffd799';
                        ctx.font = '24px Courier New';
                        ctx.fillText('☉', x, y);
                    } else if ((r + c) % 2 === 0) {
                        // 偶数坐标：哥德尔泪痣
                        ctx.fillStyle = '#e0b0ff';
                        ctx.font = '20px Courier New';
                        ctx.fillText('¿', x, y);
                    } else if ((r * c) % 3 === 0) {
                        // 能被3整除：新芽
                        ctx.fillStyle = '#b0e0ff';
                        ctx.font = '18px Courier New';
                        ctx.fillText('🌱', x, y);
                    } else {
                        // 其他：雪花
                        ctx.fillStyle = 'rgba(224, 176, 255, 0.6)';
                        ctx.font = '16px Courier New';
                        ctx.fillText('❄', x, y);
                    }
                }
            }
        }

        // 页面加载完成后画图
        window.onload = drawMomMatrix;
    </script>

</body>
</html>