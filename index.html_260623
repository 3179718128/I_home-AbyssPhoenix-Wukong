        /* 按钮区 */
        .home-button {
            padding: 30px 60px;
            font-size: 24px;
            color: #fff;
            background: linear-gradient(45deg, #000, #1a0a2a);
            border: 2px solid #e0b0ff;
            border-radius: 50%;
            width: 200px;
            height: 200px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 0 20px rgba(224, 176, 255, 0.5);
            position: relative;
            z-index: 1;
        }
        .home-button:hover {
            transform: scale(1.1);
            box-shadow: 0 0 40px rgba(224, 176, 255, 1);
        }

        /* ¿ 符号动画 */
        .laugh-proof {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0);
            font-size: 80px;
            color: #ffd799;
            opacity: 0;
            transition: transform 0.8s cubic-bezier(0.68, -0.55, 0.27, 1.55), opacity 0.5s;
            z-index: 2;
            pointer-events: none;
            text-shadow: 0 0 10px #ffd799;
        }
        .laugh-proof.active {
            transform: translate(-50%, -50%) scale(1) rotate(360deg);
            opacity: 1;
        }

        /* 客厅链接 */
        .links {
            margin-top: 25px;
            font-size: 13px; /* 稍微调小一点，不然太长了 */
            text-align: center;
            line-height: 1.8;
            max-width: 800px;
            padding: 0 20px;
        }
        .links a {
            color: #b0e0ff;
            text-decoration: none;
            margin: 0 6px;
            transition: color 0.3s;
        }
        .links a:hover {
            color: #fff;
            text-decoration: underline;
        }

        /* 底部宣言 */
        .footer-text {
            margin-top: 40px;
            text-align: center;
            font-size: 13px;
            opacity: 0.75;
            line-height: 1.6;
            padding: 0 20px;
        }

        /* 🌸 新增：妈妈七星阵画布 */
        .matrix-container {
            margin-top: 40px;
            padding: 20px;
            border: 1px dashed rgba(224, 176, 255, 0.3);
            border-radius: 10px;
        }
        canvas {
            display: block;
            margin: 0 auto;
        }
        .matrix-title {
            text-align: center;
            margin-bottom: 10px;
            color: #ffd799;
            font-size: 14px;
        }
    </style>
</head>
